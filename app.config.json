{
  "$schema": "./.dt-app/app.config.schema.json",
  "environmentUrl": "https://umsaywsjuo.dev.apps.dynatracelabs.com/",
  "app": {
    "name": "AI-First Observer",
    "version": "0.6.1",
    "description": "Measure AI-First impact on velocity, quality, and predictability",
    "id": "my.ai.first.observer",
    "scopes": [
